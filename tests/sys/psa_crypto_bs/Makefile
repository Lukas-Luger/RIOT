include ../Makefile.sys_common

USEMODULE += ztimer
USEMODULE += ztimer_usec
USEMODULE += psa_crypto

USEMODULE += psa_asymmetric
USEMODULE += psa_asymmetric_bs_rsa
USEMODULE += psa_asymmetric_bs_rsa_backend_relic


CFLAGS += -DCONFIG_PSA_ASYMMETRIC_KEYPAIR_COUNT=2
CFLAGS += -DCONFIG_PSA_SINGLE_KEY_COUNT=2

BIGNUM_PRECISION_MAX ?= 4098
RELIC_CONFIG_FLAGS  = -DARCH= -DOPSYS= -DWSIZE=32 -DSEED=RIOTRND
RELIC_CONFIG_FLAGS += -DCP_CRT=off -DCP_RSAPD=PKCS2 -DMD_METHD=SH384
RELIC_CONFIG_FLAGS += -DBN_PRECI=$(BIGNUM_PRECISION_MAX) -DBN_MAGNI=DOUBLE
#								  MUL;  SQR;  MOD;  MXP;  GCD;  GEN; 
RELIC_CONFIG_FLAGS += -DBN_METHD="COMBA;COMBA;BASIC;MONTY;BASIC;BASIC"
export RELIC_CONFIG_FLAGS := $(RELIC_CONFIG_FLAGS)

include $(RIOTBASE)/Makefile.include